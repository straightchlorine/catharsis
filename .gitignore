# ignore everything but selected dirs
*
.*

# add git related fiels
!.gitignore
!.gitsubmodules

# add zsh related files
!.zshrc
!.config/zsh
!.config/zsh/.zshrc
!.config/zsh/paths.zsh
!.config/zsh/env.zsh
!.config/zsh/dev.zsh
!.config/zsh/aliases.zsh

# add dunst config
!.config/dunst
!.config/dunst/dunstrc

# add mpd config
!.config/mpd
!.config/mpd/mpd.conf

# add zathura related files
!.config/zathura
!.config/zathura/zathurarc

# add neovim submodule
!.config/
!.config/nvim/

# add sway config
!.config/sway
!.config/sway/**

# add yazi config
!.config/yazi
!.config/yazi/keymap.toml

# add kitty config
!.config/kitty
!.config/kitty/kitty.conf
# !.config/kitty/colors <generated by colorgen>

# add waybar config
!.config/waybar
# !.config/waybar/colors.css <generated by colorgen>
!.config/waybar/config.jsonc
!.config/waybar/style.css
!.config/waybar/scripts
!.config/waybar/scripts/**
