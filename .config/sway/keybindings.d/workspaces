# Workspace output assignments and keybindings
# On single-head, output assignments are ignored and all workspaces
# land on the available screen. On multihead, they map to the right output.

# Primary workspaces → DP-1
workspace $ws1 output DP-1
workspace $ws2 output DP-1
workspace $ws3 output DP-1
workspace $ws4 output DP-1
workspace $ws5 output DP-1
workspace $ws6 output DP-1
workspace $ws7 output DP-1
workspace $ws8 output DP-1
workspace $ws9 output DP-1

# Monitor 2 workspaces → DP-2
workspace $ws2_1 output DP-2
workspace $ws2_2 output DP-2
workspace $ws2_3 output DP-2
workspace $ws2_4 output DP-2
workspace $ws2_5 output DP-2
workspace $ws2_6 output DP-2
workspace $ws2_7 output DP-2
workspace $ws2_8 output DP-2
workspace $ws2_9 output DP-2

# Monitor 3 workspaces → DP-3
workspace $ws3_1 output DP-3
workspace $ws3_2 output DP-3
workspace $ws3_3 output DP-3
workspace $ws3_4 output DP-3
workspace $ws3_5 output DP-3
workspace $ws3_6 output DP-3
workspace $ws3_7 output DP-3
workspace $ws3_8 output DP-3
workspace $ws3_9 output DP-3


# Primary workspace switching ($mod+N) — always works
bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5
bindsym $mod+6 workspace $ws6
bindsym $mod+7 workspace $ws7
bindsym $mod+8 workspace $ws8
bindsym $mod+9 workspace $ws9

# Monitor 2 workspace switching ($alt+N)
bindsym $alt+1 workspace $ws2_1
bindsym $alt+2 workspace $ws2_2
bindsym $alt+3 workspace $ws2_3
bindsym $alt+4 workspace $ws2_4
bindsym $alt+5 workspace $ws2_5
bindsym $alt+6 workspace $ws2_6
bindsym $alt+7 workspace $ws2_7
bindsym $alt+8 workspace $ws2_8
bindsym $alt+9 workspace $ws2_9

# Monitor 3 workspace switching ($ctrl+N)
bindsym $ctrl+1 workspace $ws3_1
bindsym $ctrl+2 workspace $ws3_2
bindsym $ctrl+3 workspace $ws3_3
bindsym $ctrl+4 workspace $ws3_4
bindsym $ctrl+5 workspace $ws3_5
bindsym $ctrl+6 workspace $ws3_6
bindsym $ctrl+7 workspace $ws3_7
bindsym $ctrl+8 workspace $ws3_8
bindsym $ctrl+9 workspace $ws3_9


# Move container to primary workspaces ($mod+Shift+N)
bindsym $mod+Shift+1 move container to workspace $ws1
bindsym $mod+Shift+2 move container to workspace $ws2
bindsym $mod+Shift+3 move container to workspace $ws3
bindsym $mod+Shift+4 move container to workspace $ws4
bindsym $mod+Shift+5 move container to workspace $ws5
bindsym $mod+Shift+6 move container to workspace $ws6
bindsym $mod+Shift+7 move container to workspace $ws7
bindsym $mod+Shift+8 move container to workspace $ws8
bindsym $mod+Shift+9 move container to workspace $ws9

# Move container to monitor 2 workspaces ($alt+Shift+N)
bindsym $alt+Shift+1 move container to workspace $ws2_1
bindsym $alt+Shift+2 move container to workspace $ws2_2
bindsym $alt+Shift+3 move container to workspace $ws2_3
bindsym $alt+Shift+4 move container to workspace $ws2_4
bindsym $alt+Shift+5 move container to workspace $ws2_5
bindsym $alt+Shift+6 move container to workspace $ws2_6
bindsym $alt+Shift+7 move container to workspace $ws2_7
bindsym $alt+Shift+8 move container to workspace $ws2_8
bindsym $alt+Shift+9 move container to workspace $ws2_9

# Move container to monitor 3 workspaces ($ctrl+Shift+N)
bindsym $ctrl+Shift+1 move container to workspace $ws3_1
bindsym $ctrl+Shift+2 move container to workspace $ws3_2
bindsym $ctrl+Shift+3 move container to workspace $ws3_3
bindsym $ctrl+Shift+4 move container to workspace $ws3_4
bindsym $ctrl+Shift+5 move container to workspace $ws3_5
bindsym $ctrl+Shift+6 move container to workspace $ws3_6
bindsym $ctrl+Shift+7 move container to workspace $ws3_7
bindsym $ctrl+Shift+8 move container to workspace $ws3_8
bindsym $ctrl+Shift+9 move container to workspace $ws3_9
