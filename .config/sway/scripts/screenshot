#!/bin/bash

##
# Screenshot script using slurp and grim
##

# screenshot directory
SCREENSHOT_DIR="$HOME/screenshots"
mkdir -p "$SCREENSHOT_DIR"

# current date and time for filename
TIMESTAMP=$(date +%Y-%m-%d-%H%M%S)

# screenshot modes
case "$1" in
    "area")
        grim -g "$(slurp)" "$SCREENSHOT_DIR/$TIMESTAMP.png"
        notify-send "Screenshot" "Area screenshot saved to $SCREENSHOT_DIR/$TIMESTAMP.png"
        ;;
    "area-copy")
        grim -g "$(slurp)" - | wl-copy
        notify-send "Screenshot" "Area screenshot copied to clipboard"
        ;;
    "window")
        ACTIVE_WINDOW=$(swaymsg -t get_tree | jq -r '.. | select(.focused? == true) | .rect | "\(.x),\(.y) \(.width)x\(.height)"')
        grim -g "$ACTIVE_WINDOW" "$SCREENSHOT_DIR/$TIMESTAMP.png"
        notify-send "Screenshot" "Window screenshot saved to $SCREENSHOT_DIR/$TIMESTAMP.png"
        ;;
    "full")
        grim "$SCREENSHOT_DIR/$TIMESTAMP.png"
        notify-send "Screenshot" "Full screenshot saved to $SCREENSHOT_DIR/$TIMESTAMP.png"
        ;;
    "full-copy")
        grim - | wl-copy
        notify-send "Screenshot" "Full screenshot copied to clipboard"
        ;;
    *)
        # Default: show usage
        echo "Usage: $0 [area|area-copy|window|full|full-copy]"
        echo "  area:      Save screenshot of selected area"
        echo "  area-copy: Copy screenshot of selected area to clipboard"
        echo "  window:    Save screenshot of active window"
        echo "  full:      Save full screenshot"
        echo "  full-copy: Copy full screenshot to clipboard"
        exit 1
        ;;
esac

exit 0
