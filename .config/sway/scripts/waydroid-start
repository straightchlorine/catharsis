#!/bin/bash

##
# Waydroid start script - ensures session is running before showing UI
##

notify-send "Waydroid" "Starting session..."

# Start session (will succeed even if already running)
waydroid session start 2>/dev/null

# Wait for session to be fully ready (max 10 seconds)
for i in {1..20}; do
    if waydroid status 2>/dev/null | grep -q "RUNNING"; then
        break
    fi
    sleep 0.5
done

# Show UI
waydroid show-full-ui

notify-send "Waydroid" "Session started with full UI!"

exit 0